# Public site URL for SEO, sitemap, and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://tasami-industrial.com"

# ─── Contact (public) ───────────────────────────────────────────────────────
NEXT_PUBLIC_CONTACT_EMAIL="info@tasami-industrial.com"
NEXT_PUBLIC_CONTACT_PHONE="+966 XX XXX XXXX"
# WhatsApp number with country code, digits only e.g. 9665XXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# ─── PDF assets (optional — Supabase Storage or CDN public URLs) ──────────────
# When set, downloads use hosted PDFs instead of client-generated placeholders
NEXT_PUBLIC_PDF_MARKET_REPORT=""
NEXT_PUBLIC_PDF_CHEMICAL_ANALYSIS=""
NEXT_PUBLIC_PDF_CERTIFICATES=""
NEXT_PUBLIC_PDF_TECHNICAL_FILE=""

# ─── Email notifications (Resend) ───────────────────────────────────────────
RESEND_API_KEY=""
RESEND_NOTIFY_EMAIL="sales@tasami-industrial.com"
RESEND_FROM_EMAIL="TASAMI <onboarding@resend.dev>"

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ─── Supabase ───────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Run supabase/migrations/001_contact_submissions.sql in the Supabase SQL Editor

# ─── Admin dashboard (/admin) ───────────────────────────────────────────────
ADMIN_PASSWORD="choose-a-strong-password"
# Optional: separate secret for session cookie signing (defaults to ADMIN_PASSWORD)
ADMIN_SESSION_SECRET="random-long-secret-string"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
